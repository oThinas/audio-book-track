# Test environment — copy to `.env.test` for local test runs.
# Used automatically when NODE_ENV=test (via `bun run test:integration` and `bun run test:e2e`).
#
# In test mode, only TEST_DATABASE_URL is required. DATABASE_URL is intentionally omitted
# so tests never accidentally connect to the dev database.

TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/audiobook_track_test

BETTER_AUTH_SECRET=test-secret-not-for-production
BETTER_AUTH_URL=http://localhost:1197

NODE_ENV=test